<UserControl x:Class="LyricsOnTheGo.Controls.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI Variable, Segoe UI">
    <Border Background="#1A1A1A" CornerRadius="10" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="10">
        <StackPanel Width="190">
            <!-- Saturation (x) / Value (y) field -->
            <Grid x:Name="SvArea" Width="190" Height="120"
                  MouseLeftButtonDown="SvDown" MouseMove="SvMove" MouseLeftButtonUp="SvUp">
                <Border CornerRadius="6" ClipToBounds="True">
                    <Grid>
                        <Rectangle x:Name="HueRect" />
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#FFFFFFFF" />
                                    <GradientStop Offset="1" Color="#00FFFFFF" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#00000000" />
                                    <GradientStop Offset="1" Color="#FF000000" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>
                <Canvas IsHitTestVisible="False">
                    <Ellipse x:Name="SvThumb" Width="14" Height="14" Stroke="White" StrokeThickness="2">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Color="Black" Opacity="0.7" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Canvas>
            </Grid>

            <!-- Hue bar -->
            <Grid x:Name="HueArea" Width="190" Height="14" Margin="0,12,0,0"
                  MouseLeftButtonDown="HueDown" MouseMove="HueMove" MouseLeftButtonUp="HueUp">
                <Border CornerRadius="7" ClipToBounds="True">
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#FF0000" />
                                <GradientStop Offset="0.166" Color="#FFFF00" />
                                <GradientStop Offset="0.333" Color="#00FF00" />
                                <GradientStop Offset="0.5" Color="#00FFFF" />
                                <GradientStop Offset="0.666" Color="#0000FF" />
                                <GradientStop Offset="0.833" Color="#FF00FF" />
                                <GradientStop Offset="1" Color="#FF0000" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Border>
                <Canvas IsHitTestVisible="False">
                    <Border x:Name="HueThumb" Width="5" Height="16" Margin="0,-1,0,0" Background="White"
                            CornerRadius="2" BorderBrush="#80000000" BorderThickness="1" />
                </Canvas>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="HexInput" Grid.Column="0" Height="26"
                         Background="#12FFFFFF" Foreground="White" BorderBrush="#24FFFFFF" BorderThickness="1"
                         FontFamily="Cascadia Code, Consolas" FontSize="12" CharacterCasing="Upper"
                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                         TextChanged="OnHexChanged" MaxLength="7">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>

                <!-- Eyedropper: pick a colour from anywhere on screen. -->
                <Button x:Name="EyedropperBtn" Grid.Column="1" Width="28" Height="26" Margin="8,0,0,0"
                        Cursor="Hand" Click="OnEyedropper" ToolTip="Pick from screen">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="eb" Background="#12FFFFFF" BorderBrush="#24FFFFFF"
                                    BorderThickness="1" CornerRadius="7">
                                <Viewbox Width="15" Height="15">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}"
                                              Data="M2 22l1-1h3l9-9 M3 21v-3l9-9 M15 6l3.4-3.4a2.1 2.1 0 1 1 3 3L18 9l.4.4a2.1 2.1 0 1 1-3 3l-3.8-3.8a2.1 2.1 0 1 1 3-3l.4.4z" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="eb" Property="Background" Value="#22FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
