<Window x:Class="LyricsOnTheGo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:LyricsOnTheGo.Controls"
        Title="LyricsOnTheGo"
        Width="440" Height="340"
        MinWidth="240" MinHeight="120"
        Left="200" Top="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- Thin overlay scrollbar for the lyrics (6px rounded thumb, no buttons). The thumb colour
             follows the ScrollBar.Foreground, which the code sets from the chosen text colour. -->
        <Style x:Key="LyricsScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="8">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="6" CornerRadius="3" HorizontalAlignment="Center"
                                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header chrome buttons: white glyph, transparent, subtle hover. -->
        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Background alpha=1/255: visually transparent (acrylic shows through) but the whole
         layered surface stays hit-testable for WM_NCHITTEST drag/resize. -->
    <Grid>
        <!-- Synced lyrics. The panel lives in a Canvas so it is laid out at its FULL height
             (no automatic layout-clip to the viewport slot), guaranteeing every line is
             rendered; the outer Grid clips to the viewport and the TranslateTransform scrolls. -->
        <Grid x:Name="LyricsViewport" Margin="18,0,18,0" Background="#01000000">
            <Canvas x:Name="LyricsCanvas" ClipToBounds="True">
                <StackPanel x:Name="LyricsPanel"
                            Width="{Binding ActualWidth, ElementName=LyricsViewport}">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="LyricsTranslate" Y="0" />
                    </StackPanel.RenderTransform>
                </StackPanel>
            </Canvas>
            <ScrollBar x:Name="LyricsScroll" Orientation="Vertical" HorizontalAlignment="Right"
                       Style="{StaticResource LyricsScrollBar}" Margin="0,10,-14,10"
                       Visibility="Collapsed" Scroll="OnLyricsBarScroll" />
        </Grid>

        <!-- Plain (unsynced) lyrics: manually scrollable. -->
        <ScrollViewer x:Name="PlainScroll" Margin="18,14,18,14"
                      VerticalScrollBarVisibility="Hidden"
                      Visibility="Collapsed">
            <TextBlock x:Name="PlainTextBlock"
                       Foreground="#EDEDED" FontSize="24" FontWeight="Bold"
                       TextWrapping="Wrap" LineHeight="31"
                       LineStackingStrategy="BlockLineHeight" />
        </ScrollViewer>

        <!-- Status (searching / not found / instrumental / play something). -->
        <TextBlock x:Name="StatusText"
                   Text="Play something…"
                   Foreground="White" Opacity="0.6"
                   FontSize="15"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" TextWrapping="Wrap" Margin="24" />

        <!-- Header chrome (settings / close-to-tray). Dark top gradient keeps glyphs readable. -->
        <Border x:Name="HeaderBar" VerticalAlignment="Top" Height="42" CornerRadius="12,12,0,0"
                Cursor="SizeAll" MouseLeftButtonDown="OnHeaderDrag"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="HeaderTranslate" Y="0" />
            </Border.RenderTransform>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#66000000" />
                    <GradientStop Offset="1" Color="#00000000" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="12,0,6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Now-playing title + artist (two rows). Hidden until a track is reported. -->
                <StackPanel x:Name="HeaderInfo" Grid.Column="0" VerticalAlignment="Center"
                            HorizontalAlignment="Stretch" Margin="0,0,8,0" Visibility="Collapsed">
                    <TextBlock x:Name="HeaderTitle" Foreground="White" FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" LineHeight="15"
                               LineStackingStrategy="BlockLineHeight" />
                    <TextBlock x:Name="HeaderArtist" Foreground="White" Opacity="0.65" FontSize="10.5"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" LineHeight="13"
                               LineStackingStrategy="BlockLineHeight" />
                </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:Name="KaraokeButton" Style="{StaticResource HeaderButton}" Click="OnToggleKaraoke" ToolTip="Karaoke">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="KaraokeIcon" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}"
                                  Data="M11 7.601 5.006 15.791a1 1 0 0 0 .1 1.298l.817.818a1 1 0 0 0 1.314.087L15.09 12 M16.5 21.174C15.5 20.5 14.372 20 13 20c-2.058 0-3.928 2.356-6 2-2.072-.356-2.775-3.369-1.5-4.5 M11 7 A5 5 0 1 0 21 7 A5 5 0 1 0 11 7 Z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="PinButton" Style="{StaticResource HeaderButton}" Click="OnTogglePin" ToolTip="Pin on top">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="PinIcon" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}"
                                  Data="M12 17v5 M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="SettingsButton" Style="{StaticResource HeaderButton}" Click="OnOpenSettings" ToolTip="Settings">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Fill="{x:Null}"
                                  Data="M15 12 A3 3 0 1 1 9 12 A3 3 0 1 1 15 12 M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="CloseButton" Style="{StaticResource HeaderButton}" Click="OnCloseToTray" ToolTip="Close">
                    <Viewbox Width="16" Height="16">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Fill="{x:Null}" Data="M18 6 6 18 M6 6 18 18" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
            </Grid>
        </Border>

        <!-- Footer: progress bar + current/total times (README §3.6). No background — the lyrics'
             bottom fade already opens this area, keeping the glass effect clean. The middle column
             stays * so that, when the bar is hidden but times are shown, the current/total times
             sit at the left/right edges. -->
        <Border x:Name="FooterBar" VerticalAlignment="Bottom" Padding="16,16,16,11"
                CornerRadius="0,0,12,12" Visibility="Collapsed">
            <Grid VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TimeCurrent" Grid.Column="0" Text="0:00" Foreground="White"
                           Opacity="0.7" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" />
                <Border x:Name="ProgressTrack" Grid.Column="1" Height="4" CornerRadius="2"
                        Background="#29FFFFFF" VerticalAlignment="Center">
                    <Border x:Name="ProgressFill" Height="4" CornerRadius="2" Background="#17D346"
                            HorizontalAlignment="Left" Width="0" />
                </Border>
                <TextBlock x:Name="TimeTotal" Grid.Column="2" Text="0:00" Foreground="White"
                           Opacity="0.7" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" />
            </Grid>
        </Border>

        <!-- Resync pill: appears when the user has manually scrolled the synced lyrics away from
             the active line; click to snap back and resume auto-scroll. -->
        <Button x:Name="ResyncButton" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,14" Visibility="Collapsed" Cursor="Hand" Click="OnResync"
                Content="Resync" Panel.ZIndex="10">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="rb" Background="#CC1B1B1B" BorderBrush="#33FFFFFF" BorderThickness="1"
                            CornerRadius="13" Padding="11,6">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="14" Height="14" Margin="0,0,6,0">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="{x:Null}"
                                          Data="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8 M3 3v5h5" />
                                </Canvas>
                            </Viewbox>
                            <ContentPresenter VerticalAlignment="Center" TextElement.Foreground="White"
                                              TextElement.FontSize="12" TextElement.FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="rb" Property="Background" Value="#E6262626" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Settings overlay (covers the window when open). -->
        <ctrl:SettingsPanel x:Name="SettingsOverlay" Visibility="Collapsed" />
    </Grid>
</Window>
